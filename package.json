{
  "name": "chapernoe-lm",
  "version": "1.0.0",
  "description": "LLM gateway with OpenAI-compatible API",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node --import tsx/esm src/index.ts",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write src",
    "format:check": "prettier --check src"
  },
  "dependencies": {
    "@ai-sdk/amazon-bedrock": "^3.0.71",
    "@ai-sdk/anthropic": "^3.0.75",
    "@ai-sdk/azure": "^3.0.60",
    "@ai-sdk/google": "^3.0.68",
    "@ai-sdk/google-vertex": "^4.0.122",
    "@ai-sdk/openai": "^3.0.62",
    "@ai-sdk/openai-compatible": "^2.0.46",
    "@ai-sdk/provider": "^3.0.10",
    "@ai-sdk/provider-utils": "^4.0.26",
    "ai": "^6.0.175",
    "express": "^4.18.0",
    "js-yaml": "^4.1.0",
    "openai": "^4.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^4.17.0",
    "@types/js-yaml": "^4.0.0",
    "@types/supertest": "^6.0.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "supertest": "^7.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.59.2",
    "vitest": "^2.0.0"
  }
}
